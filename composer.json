{
    "name": "marko/session",
    "description": "Session interfaces and infrastructure for Marko Framework",
    "type": "marko-module",
    "license": "MIT",
    "require": {
        "php": "^8.5",
        "marko/core": "@dev",
        "marko/config": "@dev"
    },
    "repositories": [
        { "type": "path", "url": "../core" },
        { "type": "path", "url": "../config" }
    ],
    "autoload": {
        "psr-4": {
            "Marko\\Session\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Marko\\Session\\Tests\\": "tests/"
        }
    },
    "extra": {
        "marko": {
            "module": true
        }
    }
}
